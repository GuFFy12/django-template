{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "djangoCommand",
      "type": "pickString",
      "description": "Enter Django manage.py command",
      "options": [
        "runserver_plus --nopin",
        "migrate",
        "makemigrations",
        "shell_plus",
        "createsuperuser",
        "flush"
      ],
      "default": "runserver_plus --nopin"
    }
  ],
  "tasks": [
    {
      "label": "Start development environment",
      "type": "shell",
      "command": "docker compose -f ./dev/compose.yaml up -d",
      "problemMatcher": []
    },
    {
      "label": "Create database",
      "type": "shell",
      "command": "docker exec -it dev-postgres-1 createdb -U django django_template",
      "problemMatcher": []
    },
    {
      "label": "Django: manage.py",
      "type": "shell",
      "command": "uv run python manage.py ${input:djangoCommand}",
      "problemMatcher": []
    },
    {
      "label": "Install lefthook",
      "type": "shell",
      "command": "uv run lefthook install",
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Run pre-commit for all files",
      "type": "shell",
      "command": "uv run lefthook run pre-commit --all-files",
      "problemMatcher": []
    },
    {
      "label": "Update from template",
      "type": "shell",
      "command": "uv run copier update",
      "presentation": {
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Update from template: Django",
      "type": "shell",
      "command": "uv run copier update -a .copier-answers.django.yml",
      "presentation": {
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
