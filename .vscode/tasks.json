{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run",
      "type": "shell",
      "command": "uv run python manage.py runserver_plus --nopin",
      "problemMatcher": []
    },
    {
      // Если обновили какие либо базовые настройки или сделали git pull.
      "label": "Run post-create script",
      "type": "shell",
      "command": ".devcontainer/post-create.sh",
      "problemMatcher": []
    },
    {
      // Изменили настройки линтера или форматера? Обязательно запустите.
      "label": "Run pre-commit for all files",
      "type": "shell",
      "command": "uv run lefthook run pre-commit --all-files",
      "problemMatcher": []
    },
    {
      "label": "Update from template",
      "type": "shell",
      "command": "uv run copier update",
      "presentation": { "focus": true },
      "problemMatcher": []
    },
    {
      "label": "Update from template: Django",
      "type": "shell",
      "command": "uv run copier update -a .copier-answers.django.yml",
      "presentation": { "focus": true },
      "problemMatcher": []
    },
    {
      "label": "Make Migrations",
      "type": "shell",
      "command": "uv run python manage.py makemigrations",
      "problemMatcher": []
    },
    {
      "label": "Migrate",
      "type": "shell",
      "command": "uv run python manage.py migrate",
      "problemMatcher": []
    },
    {
      "label": "Django Shell",
      "type": "shell",
      "command": "uv run python manage.py shell_plus",
      "problemMatcher": []
    },
    {
      "label": "Flush Database",
      "type": "shell",
      "command": "uv run python manage.py flush",
      "problemMatcher": []
    }
  ]
}
