{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Django",
      "type": "debugpy",
      "request": "launch",
      "args": [
        "runserver_plus",
        "--nopin"
      ],
      "django": true,
      "autoStartBrowser": true,
      "program": "${workspaceFolder}/manage.py"
    }
  ]
}
